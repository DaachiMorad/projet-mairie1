PORT=3001
NODE_ENV=development   # Mettre "production" en prod

# ── Base de données ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_strong_password
DB_NAME=laronde

# ── JWT ────────────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=24h   # Réduit de 7d → 24h recommandé

# ── CORS ────────────────────────────────────────────────────────────────────────
# En production : mettre l'URL exacte du frontend (sans slash final)
# Plusieurs origines séparées par virgule : https://app.laronde.fr,https://www.laronde.fr
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=LaRonde <noreply@laronde.fr>

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ── Admin panel ────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET


